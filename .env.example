# 🐾 Apperritos Backend - Variables de entorno
# Copia este archivo como .env y rellena los valores

# Ruta al archivo de credenciales de Firebase (Service Account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Alternativa para cloud (Render): pega aquí el JSON completo en una sola línea
# Si esta variable está definida, tiene prioridad sobre FIREBASE_SERVICE_ACCOUNT_PATH
FIREBASE_SERVICE_ACCOUNT_JSON=

# Bucket de Firebase Storage (sin gs://)
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
